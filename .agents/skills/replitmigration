### 3.4 Scroll-triggered Animations (Standard Pattern)

```tsx
// Always use: initial="hidden" whileInView="show" viewport={{ once: true, margin: "-100px" }}
// For grids: add variants with staggerChildren

<motion.div
  initial="hidden"
  whileInView="show"
  viewport={{ once: true, margin: "-100px" }}
  variants={fadeUp}
>
  Section heading here
</motion.div>

// Grid with stagger:
<motion.div
  initial="hidden"
  whileInView="show"
  viewport={{ once: true, margin: "-100px" }}
  variants={{ hidden: {}, show: { transition: { staggerChildren: 0.1 } } }}
  style={{ display: "grid", ... }}
>
  {items.map(item => (
    <motion.div key={item.id} variants={cardItem}>
      ...card content
    </motion.div>
  ))}
</motion.div>
```

