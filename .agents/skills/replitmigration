## PART 3 — ANIMATION SYSTEM

### 3.1 App-Level Setup (App.tsx)

```tsx
// AOS — re-init on every route change (so animations replay)
function AOSHandler() {
  const { pathname } = useLocation();
  useEffect(() => {
    AOS.init({ duration: 600, once: false, offset: 80 });
    AOS.refresh();
  }, [pathname]);
  return null;
}

// Lenis smooth scroll — desktop only, reset scroll on route change
function SmoothScroll() {
  const lenisRef = useRef<Lenis | null>(null);
  const { pathname } = useLocation();

  useEffect(() => {
    document.documentElement.scrollTop = 0;
    document.body.scrollTop = 0;

    if (window.innerWidth < 640) return; // Mobile: no Lenis

    lenisRef.current = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    let active = true;
    function raf(time: number) {
      if (!active) return;
      lenisRef.current?.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    return () => {
      active = false;
      lenisRef.current?.destroy();
      lenisRef.current = null;
    };
  }, [pathname]);

  return null;
}

// Page transitions — opacity only (no y offset = no layout jump)
const pageVariants = {
  initial: { opacity: 0 },
  animate: { opacity: 1, transition: { duration: 0.2, ease: "easeInOut" } },
  exit:    { opacity: 0, transition: { duration: 0.2 } },
};
```

