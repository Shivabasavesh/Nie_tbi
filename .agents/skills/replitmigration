### convex/mutations.ts (Key patterns)
```typescript
// Submit application
export const submitApplication = mutation({
  args: {
    founderName: v.string(), email: v.string(), phone: v.string(),
    startupName: v.string(), sector: v.string(), stage: v.string(),
    description: v.string(),
  },
  handler: async (ctx, args) => {
    return await ctx.db.insert("applications", {
      ...args, status: "pending", submittedAt: Date.now(),
    });
  },
});

// Send contact message
export const sendMessage = mutation({
  args: { name: v.string(), email: v.string(), phone: v.optional(v.string()), message: v.string() },
  handler: async (ctx, args) => {
    return await ctx.db.insert("messages", {
      ...args, isRead: false, submittedAt: Date.now(),
    });
  },
});
```

### React Usage (replacing Formspree)
```tsx
import { useMutation } from "convex/react";
import { api } from "../convex/_generated/api";

const sendMessage = useMutation(api.mutations.sendMessage);

const handleSubmit = async (e: React.FormEvent) => {
  e.preventDefault();
  setStatus("submitting");
  try {
    await sendMessage({ name: form.name, email: form.email, phone: form.phone, message: form.message });
    setStatus("success");
    setForm({ name: "", email: "", phone: "", message: "" });
    setTimeout(() => setStatus("idle"), 5000);
  } catch {
    setStatus("error");
  }
};
```

